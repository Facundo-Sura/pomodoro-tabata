# Database
DATABASE_URL=postgres://user:password@host:5432/dbname

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-access-token-secret
JWT_REFRESH_SECRET=your-refresh-token-secret

# Frontend — used for CORS (must match your frontend URL)
ALLOWED_ORIGIN=http://localhost:5173

# Spotify (optional — for music integration)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/music/spotify/callback

# YouTube (optional — for music integration)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/music/youtube/callback

# OpenAI — required for chat
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google OAuth (optional — for user sign-in with Google)
GOOGLE_CLIENT_ID=

# Encryption key — required for music tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
